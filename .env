# ── Trip detection mode ──────────────────────────────────────────────────────
# TRIP_ON_IGNITION: when true, every ignition-off immediately closes the active
#   trip (no idle-threshold debounce).  Every ignition-on starts a fresh trip.
#   Recommended for GT06 devices where the ACC signal is reliable.
TRIP_ON_IGNITION=true
# TRIP_MIN_IDLE_MINUTES: debounce window (minutes) when TRIP_ON_IGNITION=true.
# Trip closes only after engine has been off for this long. Default: 1.
TRIP_MIN_IDLE_MINUTES=1
# TRIP_ON_DURATION: (reserved — logic not yet implemented)
TRIP_ON_DURATION=false
